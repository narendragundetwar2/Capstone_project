from sklearn.cluster import KMeans, AgglomerativeClustering, DBSCAN
from sklearn.mixture import GaussianMixture
from sklearn.metrics import silhouette_score, davies_bouldin_score
import matplotlib.pyplot as plt
import numpy as np

def find_optimal_clusters(X, max_k=10):
    """Plot elbow and silhouette scores for K-Means."""
    inertias = []
    sil_scores = []
    K_range = range(2, max_k+1)
    
    for k in K_range:
        kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)
        labels = kmeans.fit_predict(X)
        inertias.append(kmeans.inertia_)
        sil_scores.append(silhouette_score(X, labels))
    
    # Plot elbow
    plt.figure(figsize=(12,5))
    plt.subplot(1,2,1)
    plt.plot(K_range, inertias, 'bo-')
    plt.xlabel('k')
    plt.ylabel('Inertia')
    plt.title('Elbow Method')
    
    plt.subplot(1,2,2)
    plt.plot(K_range, sil_scores, 'ro-')
    plt.xlabel('k')
    plt.ylabel('Silhouette Score')
    plt.title('Silhouette Analysis')
    plt.tight_layout()
    plt.savefig('results/elbow_silhouette.png')
    plt.show()
    
    best_k = K_range[np.argmax(sil_scores)]
    print(f"Optimal k by silhouette: {best_k}")
    return best_k

def apply_kmeans(X, n_clusters=4):
    model = KMeans(n_clusters=n_clusters, random_state=42, n_init=10)
    labels = model.fit_predict(X)
    return labels, model

def apply_hierarchical(X, n_clusters=4):
    model = AgglomerativeClustering(n_clusters=n_clusters)
    labels = model.fit_predict(X)
    return labels

def apply_dbscan(X, eps=0.5, min_samples=5):
    model = DBSCAN(eps=eps, min_samples=min_samples)
    labels = model.fit_predict(X)
    n_clusters = len(set(labels)) - (1 if -1 in labels else 0)
    n_noise = list(labels).count(-1)
    print(f"DBSCAN found {n_clusters} clusters and {n_noise} noise points.")
    return labels

def apply_gmm(X, n_components=4):
    model = GaussianMixture(n_components=n_components, random_state=42)
    labels = model.fit_predict(X)
    return labels, model
